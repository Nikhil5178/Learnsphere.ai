# Copy this file to .env.local and fill in your real values.
# Never commit .env.local to GitHub.

# Supabase (https://supabase.com -> create project -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq API (https://console.groq.com -> API Keys) — free tier available
GROQ_API_KEY=your-groq-api-key

# HuggingFace (https://huggingface.co/settings/tokens) — free, used for embeddings
# Optional: app works without it (falls back to a lower-quality embedding),
# but real semantic search needs this.
HUGGINGFACE_API_KEY=your-huggingface-token

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
